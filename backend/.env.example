APP_NAME=Tribal Match API
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/tribal_match
RUN_DB_MIGRATIONS_ON_STARTUP=false
SUPABASE_JWT_SECRET=
SENTRY_DSN=
MEDIA_UPLOAD_DIR=./storage/uploads
MEDIA_PUBLIC_BASE_URL=http://localhost:8000/uploads
